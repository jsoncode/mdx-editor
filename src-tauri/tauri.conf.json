{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "MDX Editor",
  "version": "0.1.4",
  "identifier": "com.mdx.editor",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "MDX Editor",
        "width": 1280,
        "height": 800,
        "minWidth": 900,
        "minHeight": 600
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": [
          "**"
        ]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": [
      "nsis",
      "msi"
    ],
    "shortDescription": "MDX document editor",
    "longDescription": "A single-file MDX document editor based on Markdown, with media embedding, split preview, and export.",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": {
      "icons/mdx-doc.ico": "mdx-doc.ico"
    },
    "windows": {
      "wix": {
        "language": [
          "en-US",
          "zh-CN"
        ]
      },
      "nsis": {
        "installerHooks": "windows/installer-hooks.nsh",
        "languages": [
          "English",
          "SimpChinese",
          "TradChinese",
          "French",
          "German",
          "SpanishInternational",
          "Japanese",
          "Korean"
        ],
        "displayLanguageSelector": false
      }
    },
    "fileAssociations": [
      {
        "ext": [
          "mdx"
        ],
        "name": "MDX Document",
        "description": "MDX packaged markdown document",
        "mimeType": "application/x-mdx",
        "role": "Editor"
      }
    ]
  }
}
